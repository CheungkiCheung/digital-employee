{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Digital Employee Feature List",
  "description": "Machine-readable feature state for WIP=1 agent-driven development.",
  "type": "object",
  "required": [
    "features"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "behavior",
          "verification",
          "dependencies",
          "status",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^feat-[0-9]{3}$"
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "behavior": {
            "type": "string",
            "minLength": 1
          },
          "verification": {
            "type": "string",
            "minLength": 1
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^feat-[0-9]{3}$"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "not-started",
              "active",
              "blocked",
              "passing"
            ]
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    }
  }
}

